export PATH=$HOME/bin:/usr/local/bin:$PATH
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME=""

plugins=(git z)

source $ZSH/oh-my-zsh.sh

# zsh-autosuggestions / zsh-syntax-highlighting (installed via brew, not omz plugins)
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# History
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS

# Editor
export EDITOR=nvim

# Aliases
if [ -x "$(command -v bat)" ]; then
  alias cat="bat --style=plain --paging=never --theme=base16"
elif [ -x "$(command -v batcat)" ]; then
  alias cat="batcat"
fi

alias ls="eza --long"
alias vim="nvim"
alias s="kitty +kitten ssh"

# fzf
export FZF_DEFAULT_COMMAND='ag -g ""'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# fnm
eval "$(fnm env --use-on-cd)"

# Starship
eval "$(starship init zsh)"

# Claude Code
export CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION=1

# Homebrew
export HOMEBREW_NO_INSTALL_CLEANUP=1
export HOMEBREW_NO_AUTO_UPDATE=1

# pnpm
export PNPM_HOME="/Users/cjlm/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# perl
PATH="/Users/cjlm/perl5/bin${PATH:+:${PATH}}"; export PATH;
PERL5LIB="/Users/cjlm/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"; export PERL5LIB;
PERL_LOCAL_LIB_ROOT="/Users/cjlm/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}"; export PERL_LOCAL_LIB_ROOT;
PERL_MB_OPT="--install_base \"/Users/cjlm/perl5\""; export PERL_MB_OPT;
PERL_MM_OPT="INSTALL_BASE=/Users/cjlm/perl5"; export PERL_MM_OPT;

export PATH="$HOME/.local/bin:$PATH"

function t() {
  tree -I '.git|node_modules|bower_components|.DS_Store' --dirsfirst --filelimit 15 -L ${1:-3} -aC $2
}
export PATH="$HOME/.local/bin:$PATH"
