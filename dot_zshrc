# PATH (typeset -U dedupes automatically)
typeset -U path PATH
path=(
  $HOME/bin
  $HOME/.local/bin
  /usr/local/bin
  /opt/homebrew/bin
  $path
)

# Editor
export EDITOR=nvim

# History
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_EXPIRE_DUPS_FIRST HIST_IGNORE_DUPS HIST_IGNORE_ALL_DUPS \
       HIST_IGNORE_SPACE HIST_FIND_NO_DUPS HIST_SAVE_NO_DUPS SHARE_HISTORY

# Completion (rebuild dump at most once per day)
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# Plugins (sourced directly — no oh-my-zsh)
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Aliases
alias cat="bat --style=plain --paging=never --theme=base16"
alias ls="eza --long"
alias vim="nvim"
alias s="kitty +kitten ssh"

# fzf
export FZF_DEFAULT_COMMAND='rg --files --hidden --glob "!.git"'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FUNCNEST=1000
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# fnm
eval "$(fnm env --use-on-cd)"

# zoxide (replaces oh-my-zsh's z plugin)
eval "$(zoxide init zsh)"

# Rust
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# Starship
eval "$(starship init zsh)"

# Homebrew
export HOMEBREW_NO_INSTALL_CLEANUP=1
export HOMEBREW_NO_AUTO_UPDATE=1

# Claude Code
export CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION=1

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
path=($PNPM_HOME $path)

# perl (local::lib)
PATH="$HOME/perl5/bin${PATH:+:${PATH}}"; export PATH
PERL5LIB="$HOME/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"; export PERL5LIB
PERL_LOCAL_LIB_ROOT="$HOME/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}"; export PERL_LOCAL_LIB_ROOT
PERL_MB_OPT="--install_base \"$HOME/perl5\""; export PERL_MB_OPT
PERL_MM_OPT="INSTALL_BASE=$HOME/perl5"; export PERL_MM_OPT

function t() {
  tree -I '.git|node_modules|bower_components|.DS_Store' --dirsfirst --filelimit 15 -L ${1:-3} -aC $2
}
